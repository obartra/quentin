---
/**
 * Responsive <picture>: serves AVIF, then WebP, then the JPEG fallback, at the
 * right size for the viewport. Widths + intrinsic dimensions come from
 * src/data/img-variants.json (generated by tools/optimize_images.py).
 *
 * `src` is the content path, e.g. "assets/img/hero-portrait.jpg". If an image
 * has no generated variants yet, it degrades to a plain <img> so the page
 * never breaks.
 */
import variants from '../data/img-variants.json';

interface Variant {
  width: number;
  height: number;
  widths: number[];
}

interface Props {
  src: string;
  alt: string;
  sizes?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  onerror?: string;
}

const {
  src,
  alt,
  sizes = '(min-width: 760px) 50vw, 92vw',
  loading = 'lazy',
  fetchpriority,
  class: className,
  onerror,
} = Astro.props;

const info = (variants as Record<string, Variant>)[src];
const base = src.replace(/^assets\/img\//, '').replace(/\.jpg$/i, '');
const srcset = (ext: string) =>
  info.widths.map((w) => `assets/img/${base}-${w}.${ext} ${w}w`).join(', ');

const imgAttrs: Record<string, unknown> = { src, alt, loading, decoding: 'async' };
if (info) {
  imgAttrs.width = info.width;
  imgAttrs.height = info.height;
}
if (fetchpriority) imgAttrs.fetchpriority = fetchpriority;
if (className) imgAttrs.class = className;
if (onerror) imgAttrs.onerror = onerror;
---

{
  info ? (
    <picture>
      <source type="image/avif" srcset={srcset('avif')} sizes={sizes} />
      <source type="image/webp" srcset={srcset('webp')} sizes={sizes} />
      <img {...imgAttrs} />
    </picture>
  ) : (
    <img {...imgAttrs} />
  )
}
