---
import { reader } from '../lib/content';
import Newsletter from './Newsletter.astro';
const s = await reader.singletons.settings.readOrThrow();
const showNewsletter = s.newsletter.placement === 'footer';
---
{showNewsletter && <Newsletter variant="footer" />}
<footer class="site-foot">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <span class="wordmark">Quentin&nbsp;<b>Fears</b></span>
        <p>{s.footerBlurb}</p>
      </div>
      <div class="foot-col">
        <h2>Explore</h2>
        <a href="work">Work</a>
        <a href="ideas">Ideas</a>
        <a href="speak">Speak &amp; Host</a>
        <a href="about">About</a>
        <a href="contact">Contact</a>
      </div>
      <div class="foot-col">
        <h2>Connect</h2>
        <a href={s.instagram} target="_blank" rel="noopener">Instagram &rarr; {s.instagramHandle}</a>
        <a href={s.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href="contact">Book to speak</a>
        <a href="contact">Corporate inquiry</a>
      </div>
    </div>
    <div class="foot-bottom">
      <p class="tagline">{s.tagline}</p>
      <p>&copy; <span data-year>{s.copyrightYear}</span> {s.copyrightName}. All rights reserved. <a href="privacy">Privacy</a></p>
    </div>
  </div>
</footer>
