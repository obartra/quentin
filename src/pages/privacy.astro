---
import BaseLayout from '../layouts/BaseLayout.astro';
import { reader, SITE_ORIGIN } from '../lib/content';
import { personMinimal, breadcrumb } from '../lib/jsonld';

const privacy = await reader.singletons.privacy.readOrThrow();
const O = SITE_ORIGIN;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${O}/privacy#webpage`,
      url: `${O}/privacy`,
      name: privacy.seo.ogTitle,
      isPartOf: { '@id': `${O}/#website` },
      about: { '@id': `${O}/#person` },
      inLanguage: 'en',
    },
    personMinimal(),
    breadcrumb([
      { name: 'Home', item: `${O}/` },
      { name: 'Privacy note', item: `${O}/privacy` },
    ]),
  ],
};
---
<BaseLayout
  pagePath="privacy"
  title={privacy.seo.title}
  description={privacy.seo.description}
  ogTitle={privacy.seo.ogTitle}
  ogDescription={privacy.seo.ogDescription}
  ogType={privacy.seo.ogType}
  navCurrent={null}
  jsonLd={jsonLd}
>

  <section class="page-hero">
    <div class="wrap reveal">
      <p class="eyebrow">{privacy.hero.eyebrow}</p>
      <h1>{privacy.hero.heading}</h1>
      <p>{privacy.hero.intro}</p>
      {privacy.updated && <p class="privacy-updated">Last updated {privacy.updated}.</p>}
    </div>
  </section>

  <section class="section" style="padding-top:clamp(1rem,2vw,1.5rem)">
    <div class="wrap">
      <div class="prose-narrow">
        {privacy.sections.map((sec) => (
          <div class="privacy-block reveal">
            <h2>{sec.heading}</h2>
            <p set:html={sec.body}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
