---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import Picture from '../components/Picture.astro';
import Newsletter from '../components/Newsletter.astro';
import { reader, SITE_ORIGIN } from '../lib/content';
import { personMinimal, breadcrumb } from '../lib/jsonld';

const ideas = await reader.singletons.ideas.readOrThrow();
const settings = await reader.singletons.settings.readOrThrow();
const showNewsletter = settings.newsletter.placement === 'ideas';
const O = SITE_ORIGIN;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${O}/ideas#webpage`,
      url: `${O}/ideas`,
      name: ideas.seo.ogTitle,
      isPartOf: { '@id': `${O}/#website` },
      about: { '@id': `${O}/#person` },
      inLanguage: 'en',
    },
    personMinimal(),
    breadcrumb([
      { name: 'Home', item: `${O}/` },
      { name: 'Ideas', item: `${O}/ideas` },
    ]),
  ],
};
---
<BaseLayout
  pagePath="ideas"
  title={ideas.seo.title}
  description={ideas.seo.description}
  ogTitle={ideas.seo.ogTitle}
  ogDescription={ideas.seo.ogDescription}
  ogType={ideas.seo.ogType}
  navCurrent="ideas"
  jsonLd={jsonLd}
>

  <section class="page-hero">
    <div class="wrap reveal">
      <p class="eyebrow">{ideas.hero.eyebrow}</p>
      <h1>{ideas.hero.heading}</h1>
      <p>{ideas.hero.intro}</p>
    </div>
  </section>

  <hr class="rule">

  <!-- FEATURE: TIME -->
  <section class="section">
    <div class="wrap idea-feature">
      <figure class="ph ph--tall reveal" data-tag={ideas.timeFeature.image.tag} data-label={ideas.timeFeature.image.label}>
        <Picture src={ideas.timeFeature.image.src} alt={ideas.timeFeature.image.alt} loading="lazy" sizes="(min-width: 880px) 50vw, 92vw" onerror="this.remove()" />
      </figure>
      <div class="reveal">
        <p class="eyebrow">{ideas.timeFeature.eyebrow}</p>
        <h2 class="display" style="font-size:clamp(1.8rem,3.6vw,2.8rem);margin-bottom:1.4rem">{ideas.timeFeature.heading}</h2>
        <blockquote class="pullquote">{ideas.timeFeature.pullquote}</blockquote>
        <p class="attribution">{ideas.timeFeature.attribution}</p>
        <p class="lead" style="margin-top:1.6rem">{ideas.timeFeature.lead}</p>
      </div>
    </div>
  </section>

  <hr class="rule">

  <!-- CLOSET CLEANSE THESIS -->
  <section class="section belief">
    <div class="wrap reveal">
      <p class="eyebrow eyebrow--muted">{ideas.thesis.eyebrow}</p>
      <blockquote set:html={ideas.thesis.quote}></blockquote>
      <cite>{ideas.thesis.cite}</cite>
    </div>
  </section>

  <hr class="rule">

  <!-- NOTES -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">{ideas.notes.eyebrow}</p>
        <h2>{ideas.notes.heading}</h2>
      </div>
      <div class="notes">
        {ideas.notes.items.map((n) => (
          <div class="note reveal">
            <h3>{n.title}</h3>
            <p>{n.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REELS: self-hosted vertical video (curated) or a link out to Instagram/YouTube -->
  {ideas.reels && ideas.reels.items.length > 0 && (
    <Fragment>
      <hr class="rule">
      <section class="section">
        <div class="wrap">
          <div class="sec-head reveal">
            <p class="eyebrow">{ideas.reels.eyebrow}</p>
            <h2>{ideas.reels.heading}</h2>
            {ideas.reels.intro && <p>{ideas.reels.intro}</p>}
          </div>
          <div class="reels">
            {ideas.reels.items.map((r) => {
              const platform = r.permalink && /youtu\.?be/i.test(r.permalink) ? 'YouTube' : 'Instagram';
              return r.videoSrc ? (
                <figure class="reel-card reveal" data-video={r.videoSrc} data-poster={r.poster.src} role="button" tabindex="0" aria-label={`Play reel: ${r.caption}`}>
                  <div class="ph reel-card__media" data-tag={r.poster.tag} data-label={r.poster.label}>
                    <Picture src={r.poster.src} alt={r.poster.alt} sizes="(min-width: 900px) 25vw, (min-width: 640px) 33vw, 46vw" loading="lazy" onerror="this.remove()" />
                    <span class="reel__play"><span><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" fill="#f3efe6"/></svg></span></span>
                  </div>
                  <figcaption class="reel-card__cap">{r.caption}</figcaption>
                </figure>
              ) : (
                <figure class="reel-card reveal">
                  <a class="ph reel-card__media" href={r.permalink} target="_blank" rel="noopener" aria-label={`Watch on ${platform}: ${r.caption}`} data-tag={r.poster.tag} data-label={r.poster.label}>
                    <Picture src={r.poster.src} alt={r.poster.alt} sizes="(min-width: 900px) 25vw, (min-width: 640px) 33vw, 46vw" loading="lazy" onerror="this.remove()" />
                    <span class="reel-card__ig">Watch on {platform} ↗</span>
                  </a>
                  <figcaption class="reel-card__cap">{r.caption}</figcaption>
                </figure>
              );
            })}
          </div>
        </div>
      </section>
    </Fragment>
  )}

  <hr class="rule">

  <!-- SIGNATURE FORMATS -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">{ideas.formats.eyebrow}</p>
        <h2>{ideas.formats.heading}</h2>
        <p>{ideas.formats.intro}</p>
      </div>
      <div class="format-cards">
        {ideas.formats.items.map((f) => (
          <div class="fcard reveal">
            <span class="fcard__tag">{f.tag}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {showNewsletter && <Newsletter variant="section" />}

  <Cta
    heading={ideas.cta.heading}
    body={ideas.cta.body}
    buttonLabel={ideas.cta.buttonLabel}
    buttonHref={ideas.cta.buttonHref}
  />

</BaseLayout>
